---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "A learning project building ZK-Rollup primitives in Rust" } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <title>{title} | rust-zkp</title>
  </head>
  <body>
    <nav class="nav">
      <a href={base} class="brand">rust-zkp</a>
      <div class="links">
        <a href={`${base}/docs/`}>Docs</a>
        <a href={`${base}/demos/`}>Playground</a>
        <a href="https://github.com/egpivo/rust-zkp" target="_blank" rel="noopener">GitHub</a>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <p>Built as a learning project · <a href="https://github.com/egpivo/rust-zkp">source</a></p>
    </footer>

    <style is:global>
      :root {
        --fg: #1a1a1a;
        --fg-muted: #555;
        --bg: #fafafa;
        --accent: #0066cc;
        --border: #e0e0e0;
        --code-bg: #f5f5f5;
        --max-width: 920px;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        font-size: 16px;
        line-height: 1.65;
        color: var(--fg);
        background: var(--bg);
      }

      .nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 16px 24px;
        border-bottom: 1px solid var(--border);
      }

      .nav .brand {
        font-weight: 700;
        font-family: ui-monospace, "SF Mono", Menlo, monospace;
        color: var(--fg);
        text-decoration: none;
      }

      .nav .links {
        display: flex;
        gap: 24px;
      }

      .nav .links a {
        color: var(--fg-muted);
        text-decoration: none;
        font-size: 15px;
      }

      .nav .links a:hover {
        color: var(--accent);
      }

      main {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 32px 24px 80px;
      }

      footer {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 24px;
        border-top: 1px solid var(--border);
        font-size: 14px;
        color: var(--fg-muted);
        text-align: center;
      }

      footer a {
        color: var(--fg-muted);
      }

      h1, h2, h3 { line-height: 1.3; }
      h1 { font-size: 2rem; margin-top: 0.5rem; }
      h2 { margin-top: 2.4rem; }
      h3 { margin-top: 1.8rem; }

      a { color: var(--accent); }

      code {
        font-family: ui-monospace, "SF Mono", Menlo, monospace;
        background: var(--code-bg);
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 0.9em;
      }

      pre {
        background: var(--code-bg);
        padding: 16px;
        border-radius: 6px;
        overflow-x: auto;
        font-size: 0.9em;
        line-height: 1.5;
      }

      pre code {
        background: none;
        padding: 0;
      }

      table {
        border-collapse: collapse;
        margin: 16px 0;
        width: 100%;
      }

      th, td {
        text-align: left;
        padding: 8px 12px;
        border: 1px solid var(--border);
      }

      th {
        background: var(--code-bg);
        font-weight: 600;
      }

      blockquote {
        border-left: 3px solid var(--accent);
        margin-left: 0;
        padding-left: 16px;
        color: var(--fg-muted);
      }
    </style>
  </body>
</html>
