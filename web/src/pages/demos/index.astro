---
import Layout from '../../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

const demos = [
  {
    slug: "commit",
    title: "Pedersen Commitment",
    desc: "Commit to a value with a blinding factor. Hiding + binding.",
    status: "live",
  },
  {
    slug: "sigma",
    title: "Sigma Protocol",
    desc: "Prove knowledge of a discrete log without revealing it.",
    status: "live",
  },
  {
    slug: "merkle",
    title: "Merkle Membership",
    desc: "Prove an element belongs to a set using only the root.",
    status: "live",
  },
  {
    slug: "range",
    title: "Range Proof",
    desc: "Prove a value is in a range via bit decomposition.",
    status: "live",
  },
  {
    slug: "bit-or",
    title: "Bit-OR (binary Pedersen)",
    desc: "Prove a committed bit is 0 or 1 with a Schnorr disjunction + Fiat–Shamir.",
    status: "live",
  },
  {
    slug: "send",
    title: "Transaction Builder",
    desc: "Sign a transaction in browser, submit to your rollup server.",
    status: "live",
  },
  {
    slug: "accounts",
    title: "Account Explorer",
    desc: "Fetch /accounts from the API and inspect balances and nonces.",
    status: "live",
  },
  {
    slug: "mempool",
    title: "Mempool Stream",
    desc: "Live WebSocket feed: see batches drained in real time.",
    status: "live",
  },
];
---

<Layout title="Playground">
  <h1>Playground</h1>
  <p class="subtitle">
    Interactive demos powered by the Rust ZKP library compiled to WebAssembly.
    Pedersen, Sigma, Merkle, range, and bit-OR demos run entirely in your browser.
    <strong>Transaction Builder</strong>, <strong>Account Explorer</strong>, and <strong>Mempool Stream</strong>
    call a rollup HTTP/WebSocket URL (defaults to the hosted demo API); point them at <code>http://localhost:3000</code> when you run <code>cargo run --bin zkp</code> locally.
    If the hosted API is cold, the first request can take ~30–60s — retry once.
  </p>

  <div class="demo-grid">
    {demos.map(demo => (
      <a
        href={demo.status === "live" ? `${base}/demos/${demo.slug}` : "#"}
        class={`demo-card ${demo.status}`}
        aria-disabled={demo.status !== "live"}
      >
        <div class="header">
          <h3>{demo.title}</h3>
          {demo.status !== "live" && <span class="badge">coming soon</span>}
        </div>
        <p>{demo.desc}</p>
      </a>
    ))}
  </div>

  <style>
    .subtitle { color: var(--fg-muted); margin-top: -8px; }
    .demo-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 16px;
      margin-top: 32px;
    }
    .demo-card {
      display: block;
      padding: 20px;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: white;
      text-decoration: none;
      color: var(--fg);
      transition: border-color 0.1s, background 0.1s;
    }
    .demo-card.live:hover {
      border-color: var(--accent);
      background: #f5faff;
    }
    .demo-card.soon {
      opacity: 0.55;
      cursor: not-allowed;
    }
    .demo-card .header {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
    }
    .demo-card h3 {
      margin: 0;
      font-size: 1.1rem;
    }
    .demo-card .badge {
      font-size: 0.7rem;
      padding: 2px 8px;
      background: var(--code-bg);
      border-radius: 999px;
      color: var(--fg-muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .demo-card p {
      margin: 0;
      color: var(--fg-muted);
      font-size: 0.95rem;
    }
  </style>
</Layout>
